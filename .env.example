# ── Docker deployment ─────────────────────────────────────────────────────────
# Auto-create the PocketBase admin account on first boot.
# The superuser upsert command is idempotent — safe to leave set after first run.
PB_ADMIN_EMAIL=admin@example.com
PB_ADMIN_PASSWORD=changeme123

# ── Vision API (nutrition label scanning) ─────────────────────────────────────
# Optional. If all three are set, users can scan nutrition labels with AI vision.
# Works with any OpenAI-compatible API (OpenRouter, OpenAI, Ollama, etc.)
VISION_API_URL=https://openrouter.ai/api/v1
VISION_API_KEY=
VISION_MODEL=google/gemini-2.0-flash-001

# ── Frontend development only ─────────────────────────────────────────────────
# When running `npm run dev`, set this to point at your local Go/PocketBase backend.
# Not needed for Docker deployments — the URL is baked into the image at build time.
VITE_PB_URL=http://localhost:8090
